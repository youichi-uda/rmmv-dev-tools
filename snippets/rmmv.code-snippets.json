{
  "RMMV: Alias Pattern": {
    "scope": "javascript",
    "prefix": "rmmv-alias",
    "description": "Alias an existing prototype method (safe override pattern)",
    "body": [
      "var _${1:Class}_${2:method} = ${1:Class}.prototype.${2:method};",
      "${1:Class}.prototype.${2:method} = function(${3}) {",
      "\t_${1:Class}_${2:method}.call(this${4:});",
      "\t$0",
      "};"
    ]
  },
  "RMMV: Plugin Command Handler": {
    "scope": "javascript",
    "prefix": "rmmv-command",
    "description": "Override Game_Interpreter.pluginCommand to handle plugin commands",
    "body": [
      "var _Game_Interpreter_pluginCommand = Game_Interpreter.prototype.pluginCommand;",
      "Game_Interpreter.prototype.pluginCommand = function(command, args) {",
      "\t_Game_Interpreter_pluginCommand.call(this, command, args);",
      "\tif (command === PLUGIN_NAME) {",
      "\t\tswitch (args[0]) {",
      "\t\t\tcase \"${1:commandName}\":",
      "\t\t\t\t$0",
      "\t\t\t\tbreak;",
      "\t\t}",
      "\t}",
      "};"
    ]
  },
  "RMMV: Parameter Parsing": {
    "scope": "javascript",
    "prefix": "rmmv-param",
    "description": "Parse plugin parameters from the annotation block",
    "body": [
      "var param = {",
      "\t${1:key}: parameters[\"${1:key}\"] || \"${2:default}\",$0",
      "};"
    ]
  },
  "RMMV: Full Plugin Scaffold": {
    "scope": "javascript",
    "prefix": "rmmv-plugin",
    "description": "Complete MV plugin template with annotation block and parameters",
    "body": [
      "/*:",
      " * @target MV",
      " * @plugindesc ${1:Plugin description}",
      " * @author ${2:Author}",
      " * @url ${3:https://}",
      " *",
      " * @help",
      " * ${4:Help text for this plugin.}",
      " *",
      " * @param ${5:paramName}",
      " * @text ${6:Parameter Label}",
      " * @type ${7:string}",
      " * @default ${8:}",
      " * @desc ${9:Parameter description}",
      " */",
      "",
      "(function() {",
      "\t\"use strict\";",
      "",
      "\tvar PLUGIN_NAME = \"${10:${TM_FILENAME_BASE}}\";",
      "\tvar parameters = PluginManager.parameters(PLUGIN_NAME);",
      "",
      "\tvar param = {",
      "\t\t${5:paramName}: parameters[\"${5:paramName}\"] || \"${8:}\",",
      "\t};",
      "",
      "\t$0",
      "})();"
    ]
  },
  "RMMV: Scene Class": {
    "scope": "javascript",
    "prefix": "rmmv-scene",
    "description": "Scene class template extending Scene_Base",
    "body": [
      "function Scene_${1:Custom}() {",
      "\tthis.initialize.apply(this, arguments);",
      "}",
      "",
      "Scene_${1:Custom}.prototype = Object.create(Scene_Base.prototype);",
      "Scene_${1:Custom}.prototype.constructor = Scene_${1:Custom};",
      "",
      "Scene_${1:Custom}.prototype.initialize = function() {",
      "\tScene_Base.prototype.initialize.call(this);",
      "\t$0",
      "};",
      "",
      "Scene_${1:Custom}.prototype.create = function() {",
      "\tScene_Base.prototype.create.call(this);",
      "};",
      "",
      "Scene_${1:Custom}.prototype.start = function() {",
      "\tScene_Base.prototype.start.call(this);",
      "};",
      "",
      "Scene_${1:Custom}.prototype.update = function() {",
      "\tScene_Base.prototype.update.call(this);",
      "};"
    ]
  },
  "RMMV: Window Class": {
    "scope": "javascript",
    "prefix": "rmmv-window",
    "description": "Window class template extending Window_Base (MV x,y,width,height constructor)",
    "body": [
      "function Window_${1:Custom}(x, y, width, height) {",
      "\tthis.initialize(x, y, width, height);",
      "}",
      "",
      "Window_${1:Custom}.prototype = Object.create(Window_Base.prototype);",
      "Window_${1:Custom}.prototype.constructor = Window_${1:Custom};",
      "",
      "Window_${1:Custom}.prototype.initialize = function(x, y, width, height) {",
      "\tWindow_Base.prototype.initialize.call(this, x, y, width, height);",
      "\t$0",
      "};",
      "",
      "Window_${1:Custom}.prototype.update = function() {",
      "\tWindow_Base.prototype.update.call(this);",
      "};",
      "",
      "Window_${1:Custom}.prototype.refresh = function() {",
      "\tthis.contents.clear();",
      "\tthis.drawAllItems();",
      "};"
    ]
  },
  "RMMV: Sprite Class": {
    "scope": "javascript",
    "prefix": "rmmv-sprite",
    "description": "Sprite class template extending Sprite",
    "body": [
      "function Sprite_${1:Custom}() {",
      "\tthis.initialize.apply(this, arguments);",
      "}",
      "",
      "Sprite_${1:Custom}.prototype = Object.create(Sprite.prototype);",
      "Sprite_${1:Custom}.prototype.constructor = Sprite_${1:Custom};",
      "",
      "Sprite_${1:Custom}.prototype.initialize = function() {",
      "\tSprite.prototype.initialize.call(this);",
      "\t$0",
      "};",
      "",
      "Sprite_${1:Custom}.prototype.update = function() {",
      "\tSprite.prototype.update.call(this);",
      "};",
      "",
      "Sprite_${1:Custom}.prototype.destroy = function(options) {",
      "\tSprite.prototype.destroy.call(this, options);",
      "};"
    ]
  },
  "RMMV: IIFE Wrapper": {
    "scope": "javascript",
    "prefix": "rmmv-iife",
    "description": "Immediately Invoked Function Expression wrapper",
    "body": [
      "(function() {",
      "\t\"use strict\";",
      "",
      "\t$0",
      "})();"
    ]
  }
}
