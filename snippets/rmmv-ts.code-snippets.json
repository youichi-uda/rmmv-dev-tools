{
  "RMMV TS: Typed Alias Pattern": {
    "scope": "typescript",
    "prefix": "rmmv-alias",
    "description": "Alias an existing prototype method with typed this parameter",
    "body": [
      "const _${1:Class}_${2:method} = ${1:Class}.prototype.${2:method};",
      "${1:Class}.prototype.${2:method} = function(this: ${1:Class}${3:}) {",
      "\t_${1:Class}_${2:method}.call(this${4:});",
      "\t$0",
      "};"
    ]
  },
  "RMMV TS: Plugin Command Handler": {
    "scope": "typescript",
    "prefix": "rmmv-command",
    "description": "Override Game_Interpreter.pluginCommand with typed parameters",
    "body": [
      "const _Game_Interpreter_pluginCommand = Game_Interpreter.prototype.pluginCommand;",
      "Game_Interpreter.prototype.pluginCommand = function(this: Game_Interpreter, command: string, args: string[]): void {",
      "\t_Game_Interpreter_pluginCommand.call(this, command, args);",
      "\tif (command === PLUGIN_NAME) {",
      "\t\tswitch (args[0]) {",
      "\t\t\tcase \"${1:commandName}\":",
      "\t\t\t\t$0",
      "\t\t\t\tbreak;",
      "\t\t}",
      "\t}",
      "};"
    ]
  },
  "RMMV TS: Full Plugin Scaffold": {
    "scope": "typescript",
    "prefix": "rmmv-plugin",
    "description": "Complete TypeScript MV plugin template with annotation block and parameters",
    "body": [
      "/*:",
      " * @target MV",
      " * @plugindesc ${1:Plugin description}",
      " * @author ${2:Author}",
      " * @url ${3:https://}",
      " *",
      " * @help",
      " * ${4:Help text for this plugin.}",
      " *",
      " * @param ${5:paramName}",
      " * @text ${6:Parameter Label}",
      " * @type ${7:string}",
      " * @default ${8:}",
      " * @desc ${9:Parameter description}",
      " */",
      "",
      "((): void => {",
      "\t\"use strict\";",
      "",
      "\tconst PLUGIN_NAME = \"${10:${TM_FILENAME_BASE}}\";",
      "\tconst parameters = PluginManager.parameters(PLUGIN_NAME);",
      "",
      "\tconst param = {",
      "\t\t${5:paramName}: parameters[\"${5:paramName}\"] || \"${8:}\",",
      "\t};",
      "",
      "\t$0",
      "})();"
    ]
  },
  "RMMV TS: Parameter Parsing": {
    "scope": "typescript",
    "prefix": "rmmv-param",
    "description": "Parse plugin parameters with type annotations",
    "body": [
      "const param = {",
      "\t${1:key}: parameters[\"${1:key}\"] || \"${2:default}\",$0",
      "};"
    ]
  },
  "RMMV TS: IIFE Wrapper": {
    "scope": "typescript",
    "prefix": "rmmv-iife",
    "description": "Immediately Invoked Function Expression wrapper",
    "body": [
      "((): void => {",
      "\t\"use strict\";",
      "",
      "\t$0",
      "})();"
    ]
  }
}
